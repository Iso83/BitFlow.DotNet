@page "/rewrite"
@rendermode InteractiveServer
@inject IJSRuntime JS

@using System.Net.Http.Json
@using System.Text.Json


<h1>BitFlow Rewrite</h1>

<form @onsubmit="HandleSubmit" @onsubmit:preventDefault>

	<div class="mb-3">
		<input class="form-control"
			   @bind="Expression"
			   @bind:event="oninput"
			   style="font-family: Consolas, monospace;"
			   placeholder="Expression" />

		@if (ErrorPosition >= 0)
		{
			<pre class="text-danger mb-0 error-marker">@ErrorMarker</pre>
		}
	</div>
	<div class="mb-4">
		<button class="btn btn-primary"
				type="submit">
			Rewrite
		</button>
	</div>


	@if (DebugEnabled)
	{
		<div class="card mt-4" border-warning>
			<div class="card-header d-flex justify-content-between bg-warning-subtle">
				<span>Debug</span>
				<button class="btn btn-sm btn-secondary"
						@onclick="CopyDebug"
						disabled="@(!CanCopyDebug)">
					Copy
				</button>
			</div>
			<div class="card-body">
				<textarea class="form-control" bg-warning-subtle
						  rows="10"
						  readonly>@DebugText</textarea>
			</div>
		</div>
	}

</form>

@if (!string.IsNullOrWhiteSpace(Error))
{
	<div class="alert alert-danger">
		@Error
	</div>
}

@if (Result != null)
{
	<div @ref="latexRoot" @key="Result?.parsed + Result?.rewritten">
		<div class="card mb-3">
			<div class="card-header">Parsed</div>
			<div class="card-body">
				@($"$$ {Result.parsed} $$")
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-header">Rewritten</div>
			<div class="card-body">
				@($"$$ {Result.rewritten} $$")
			</div>
		</div>

		<h3>Trace</h3>

		@foreach (var step in Result.trace)
		{
			<div class="card mb-3">
				<div class="card-header">
					@step.rule
				</div>

				<div class="card-body">
					<div><b>Before</b></div>
					<code>@step.before</code>

					<hr />

					<div><b>After</b></div>
					<code>@step.after</code>
				</div>
			</div>
		}
	</div>
}

@code {

	private ElementReference latexRoot;
	private string Expression = "a^b^a";

	private RewriteResponse? Result;
	private string? Error;

	private int ErrorPosition = -1;

	private string ErrorMarker =>
		ErrorPosition < 0
			? ""
			: new string(' ', ErrorPosition) + "^";

	[SupplyParameterFromQuery(Name = "debug")]
	public string? DebugQuery { get; set; }

	private uint DebugFlags;
	private string DebugText = "";
	private bool DebugEnabled => DebugFlags != 0;

	protected override void OnParametersSet()
	{
		DebugFlags = ParseDebugFlags(DebugQuery);
	}

	private static uint ParseDebugFlags(string? debug)
	{
		if (string.IsNullOrWhiteSpace(debug))
			return 0;

		uint flags = 0;

		foreach (var part in debug.Split(',',
					StringSplitOptions.RemoveEmptyEntries |
					StringSplitOptions.TrimEntries))
		{

			switch (part.ToLowerInvariant())
			{
				case "groups":
					flags |= (uint)Native.BF_PrintFlags.BF_PRINT_EXPLICIT_GROUPS;
					break;

				case "ids":
					flags |= (uint)Native.BF_PrintFlags.BF_PRINT_SHOW_EXPR_IDS;
					break;

				case "ops":
					flags |= (uint)Native.BF_PrintFlags.BF_PRINT_SHOW_OP_TYPES;
					break;

				case "bw":
					flags |= (uint)Native.BF_PrintFlags.BF_PRINT_SHOW_BITWIDTH;
					break;

				case "structure":
					flags |= (uint)Native.BF_PrintFlags.BF_PRINT_DEBUG_STRUCTURE;
					break;
			}
		}

		return flags;
	}

	private async Task CopyDebug()
	{
		try
		{
			var text =
			$"""
		BitFlow Debug

		Mode:
			{DebugQuery}

		Input:
			{Expression}

		Debug:
			{DebugText}
		""";

			await JS.InvokeVoidAsync(
				"copyText",
				text);
		}
		catch (Exception ex)
		{
			Error = ex.Message;
		}
	}

	private bool CanCopyDebug => Result != null && !string.IsNullOrWhiteSpace(Result.DebugText);

	private Task RunRewrite()
	{
		Error = null;
		ErrorPosition = -1;
		Result = null;

		try
		{
			using var ctx = new Native.BitFlowContext();

			var parsedId = ctx.Parse(Expression);
			var rewrittenId = ctx.Rewrite(parsedId);

			var traceJson = ctx.GetTraceJson();

			Result = new RewriteResponse
			{
				DebugText = ctx.ToTextEx(
					parsedId,
					DebugFlags),
				input = Expression,
				parsed = ctx.ToLatex(parsedId),
				rewritten = ctx.ToLatex(rewrittenId),
				trace = JsonSerializer.Deserialize<List<RewriteStep>>(traceJson) ?? []
			};

			DebugText = Result.DebugText;
		}
		catch (Exception ex)
		{
			Error = ex.Message;

			var match = System.Text.RegularExpressions.Regex.Match(
				ex.Message,
				@"position\s+(\d+)"
			);

			if (match.Success)
				ErrorPosition = int.Parse(match.Groups[1].Value);
		}

		return Task.CompletedTask;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (Result != null)
		{
			await JS.InvokeVoidAsync(
				"bitflowRenderLatex",
				latexRoot
			);
		}
	}

	public class RewriteResponse
	{
		public string DebugText { get; set; } = "";
		public string input { get; set; } = "";
		public string parsed { get; set; } = "";
		public string rewritten { get; set; } = "";

		public List<RewriteStep> trace { get; set; } = [];
	}

	public class RewriteStep
	{
		public string rule { get; set; } = "";
		public string before { get; set; } = "";
		public string after { get; set; } = "";
	}

	private async Task HandleSubmit()
	{
		await RunRewrite();
	}
}