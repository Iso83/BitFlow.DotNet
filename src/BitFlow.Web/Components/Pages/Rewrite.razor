@page "/rewrite"
@rendermode InteractiveServer
@inject IJSRuntime JS

@using System.Net.Http.Json
@using System.Text.Json


<h1>BitFlow Rewrite</h1>

<form @onsubmit="HandleSubmit" @onsubmit:preventDefault>

	<div class="mb-3">
		<input class="form-control"
			   @bind="Expression"
			   @bind:event="oninput"
			   style="font-family: Consolas, monospace;"
			   placeholder="Expression" />

		@if (ErrorPosition >= 0)
		{
			<pre class="text-danger mb-0 error-marker">@ErrorMarker</pre>
		}
	</div>

	<div class="mb-4">
		<button class="btn btn-primary"
				type="submit">
			Rewrite
		</button>
	</div>

</form>

@if (!string.IsNullOrWhiteSpace(Error))
{
	<div class="alert alert-danger">
		@Error
	</div>
}

@if (Result != null)
{
	<div @ref="latexRoot" @key="Result?.parsed + Result?.rewritten">
		<div class="card mb-3">
			<div class="card-header">Parsed</div>
			<div class="card-body">
				@($"$$ {Result.parsed} $$")
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-header">Rewritten</div>
			<div class="card-body">
				@($"$$ {Result.rewritten} $$")
			</div>
		</div>

		<h3>Trace</h3>

		@foreach (var step in Result.trace)
		{
			<div class="card mb-3">
				<div class="card-header">
					@step.rule
				</div>

				<div class="card-body">
					<div><b>Before</b></div>
					<code>@step.before</code>

					<hr />

					<div><b>After</b></div>
					<code>@step.after</code>
				</div>
			</div>
		}
	</div>
}

@code {

	private ElementReference latexRoot;
	private string Expression = "a^b^a";

	private RewriteResponse? Result;
	private string? Error;

	private int ErrorPosition = -1;

	private string ErrorMarker =>
		ErrorPosition < 0
			? ""
			: new string(' ', ErrorPosition) + "^";

#if DEBUG
	[Inject]
	private HttpClient Http { get; set; } = default!;
#endif

#if DEBUG
	private async Task RunRewrite()
	{
		Error = null;
		ErrorPosition = -1;
		Result = null;

		try
		{
			var response = await Http.GetAsync(
				$"/api/rewrite?expr={Uri.EscapeDataString(Expression)}"
			);

			if (!response.IsSuccessStatusCode)
			{
				Error = await response.Content.ReadAsStringAsync();

var match = System.Text.RegularExpressions.Regex.Match(
					Error,
					@"position\s+(\d+)"
				);

				if (match.Success)
					ErrorPosition = int.Parse(match.Groups[1].Value);

				return;
			}

			Result = await response.Content.ReadFromJsonAsync<RewriteResponse>();
		}
		catch (Exception ex)
		{
			Error = ex.Message;
		}
	}
#else
	private Task RunRewrite()
	{
		Error = null;
		ErrorPosition = -1;
		Result = null;

		try
		{
			using var ctx = new Native.BitFlowContext();

			var parsedId = ctx.Parse(Expression);
			var rewrittenId = ctx.Rewrite(parsedId);

			var traceJson = ctx.GetTraceJson();

			Result = new RewriteResponse
			{
				input = Expression,
				parsed = ctx.ToLatex(parsedId),
				rewritten = ctx.ToLatex(rewrittenId),
				trace = JsonSerializer.Deserialize<List<RewriteStep>>(traceJson) ?? []
			};
		}
		catch (Exception ex)
		{
			Error = ex.Message;

			var match = System.Text.RegularExpressions.Regex.Match(
				ex.Message,
				@"position\s+(\d+)"
			);

			if (match.Success)
				ErrorPosition = int.Parse(match.Groups[1].Value);
		}

		return Task.CompletedTask;
	}
#endif

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (Result != null)
		{
			await JS.InvokeVoidAsync(
				"bitflowRenderLatex",
				latexRoot
			);
		}
	}

	public class RewriteResponse
	{
		public string input { get; set; } = "";
		public string parsed { get; set; } = "";
		public string rewritten { get; set; } = "";

		public List<RewriteStep> trace { get; set; } = [];
	}

	public class RewriteStep
	{
		public string rule { get; set; } = "";
		public string before { get; set; } = "";
		public string after { get; set; } = "";
	}

	private async Task HandleSubmit()
	{
		await RunRewrite();
	}
}