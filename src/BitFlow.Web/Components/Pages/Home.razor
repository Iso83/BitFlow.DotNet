@page "/"

@inject NavigationManager Nav

@code {
    protected override void OnInitialized()
    {
        if (OperatingSystem.IsWindows())
        {
            Nav.NavigateTo(
                "/rewrite?debug=groups,ops",
                replace: true);
        }
        else
        {
            Nav.NavigateTo(
                "/rewrite",
                replace: true);
        }
    }
}
